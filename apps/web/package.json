{
  "name": "@albuquerque/web",
  "version": "1.0.0",
  "description": "Web application - RedwoodSDK",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "dev": "vite dev",
    "dev:init": "rw-scripts dev-init",
    "preview": "vite preview",
    "worker:run": "rw-scripts worker-run",
    "clean": "rm -rf ./node_modules/.vite",
    "release": "rw-scripts ensure-deploy-env && pnpm clean && pnpm build && wrangler deploy",
    "generate": "rw-scripts ensure-env && wrangler types --include-runtime false",
    "check": "pnpm generate && pnpm types",
    "types": "tsc",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md}\""
  },
  "dependencies": {
    "@base-ui/react": "^1.0.0",
    "@chroma-core/chroma-cloud-splade": "^0.1.10",
    "@chroma-core/jina": "^0.1.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/space-grotesk": "^5.2.10",
    "@phosphor-icons/react": "^2.1.10",
    "@tanstack/react-query": "^5.90.18",
    "better-auth": "^1.3.34",
    "chromadb": "^3.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "cookie": "^1.0.2",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "kysely": "^0.28.8",
    "nanoid": "^5.1.6",
    "next-themes": "^0.4.6",
    "react": "19.3.0-canary-bef88f7c-20260116",
    "react-day-picker": "^9.11.2",
    "react-dom": "19.3.0-canary-bef88f7c-20260116",
    "react-resizable-panels": "^3.0.6",
    "react-server-dom-webpack": "19.3.0-canary-bef88f7c-20260116",
    "recharts": "2.15.4",
    "rwsdk": "1.0.0-beta.54",
    "shadcn": "^3.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.17",
    "tw-animate-css": "^1.4.0",
    "use-debounce": "^10.0.6",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.25.1",
    "@cloudflare/vitest-pool-workers": "^0.10.10",
    "@cloudflare/workers-types": "^4.20260219.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.17",
    "@types/node": "~24.5.2",
    "@types/react": "19.2.8",
    "@types/react-dom": "19.2.3",
    "vite": "7.2.4",
    "wrangler": "^4.66.0"
  }
}
