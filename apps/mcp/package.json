{
  "name": "@albuquerque/mcp",
  "version": "1.0.0",
  "description": "Lored MCP server with GitHub OAuth",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run --outdir=dist",
    "release": "wrangler deploy",
    "clean": "rm -rf dist .wrangler",
    "check": "pnpm generate && pnpm types",
    "generate": "wrangler types --include-runtime false",
    "types": "tsc"
  },
  "dependencies": {
    "@cloudflare/workers-oauth-provider": "^0.2.3",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "agents": "^0.4.1",
    "hono": "^4.11.9",
    "octokit": "^5.0.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260212.0",
    "typescript": "5.8.3",
    "wrangler": "^4.65.0"
  }
}
